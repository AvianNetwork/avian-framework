{
  "name": "@avian-framework/avian-rpc",
  "version": "0.1.0",
  "description": "Typed Avian Core RPC client with PSBT support, wrapping @aviannetwork/avian-rpc",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "require": "./dist/index.js",
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "@aviannetwork/avian-rpc": "^2.1.3"
  },
  "devDependencies": {
    "@types/node": "*",    "typescript": "^6.0.0",
    "rimraf": "*"
  }
}
